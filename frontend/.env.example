#  CLERK AUTHENTICATION (PUBLIC) 
# Publishable key for the Clerk frontend (found in your Clerk dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_clerk_publishable_key"

# Clerk UI Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/"


# CLERK AUTHENTICATION (SECRET) 
# Secret key for Clerk backend API calls (keep this private)
CLERK_SECRET_KEY="sk_test_your_clerk_secret_key"


#  BACKEND API CONFIGURATION 
# URL pointing to the FastAPI backend server (default local development URL)
NEXT_PUBLIC_API_URL="http://localhost:8000"
