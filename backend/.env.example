#  SUPABASE CONFIGURATION
# Database connection URL for PostgreSQL (used by SQLAlchemy for users, rooms, etc.)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Supabase API URL and Service Role Key (used for PDF storage and admin tasks)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_KEY="your_supabase_service_role_key"

# Supabase Storage Bucket name for storing PDF uploads
SUPABASE_STORAGE_BUCKET="study_lessons"


#  CLERK CONFIGURATION 
# Secret used to verify Clerk user webhooks securely
CLERK_WEBHOOK_SECRET="whsec_your_clerk_webhook_secret"


#  GOOGLE GEMINI / AI CONFIGURATION 
# API Key for Google Generative AI (Gemini Studio)
GOOGLE_API_KEY="your_google_api_key_here"

# Model to use for chat, exam, and flashcard generation 
# (e.g., gemini-1.5-flash, gemini-2.0-flash, gemma-2-9b-it)
GOOGLE_CHAT_MODEL="gemini-2.5-flash"


#  PINECONE VECTOR DATABASE 
# API Key for Pinecone (used for RAG document embeddings)
PINECONE_API_KEY="pcsk_your_pinecone_api_key_here"
